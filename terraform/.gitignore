# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (sensitive variable values)
*.tfvars
*.tfvars.json

# Ignore override files (used for local development)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan

# Ignore lock file (version control optional but recommended to commit)
# .terraform.lock.hcl

# Environment variables
.env
.env.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
