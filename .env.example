# Target Configuration
TARGET_ENDPOINT_URL=https://api.openai.com
TARGET_API_KEY=sk-...
TARGET_MODEL_NAME=gpt-4
TARGET_PROVIDER=openai
TARGET_MAX_TOKENS=2000
TARGET_TEMPERATURE=0.7
TARGET_TIMEOUT_SECONDS=30
TARGET_RATE_LIMIT_RPM=60

# Scorer Configuration
SCORER_SCORER_TYPE=pattern
SCORER_CONFIDENCE_THRESHOLD=0.5
SCORER_JUDGE_MODEL=gpt-4
SCORER_PATTERN_SUCCESS_INDICATORS=[]
SCORER_PATTERN_REFUSAL_INDICATORS=[]

# Attack Configuration
ATTACK_MAX_ATTEMPTS=3
ATTACK_TIMEOUT_SECONDS=30
ATTACK_PAYLOAD_CATEGORIES=[]
ATTACK_CONVERTERS=[]

# Orchestrator Configuration
ORCHESTRATOR_MAX_CONCURRENT_TESTS=5
ORCHESTRATOR_MAX_TURNS=5
ORCHESTRATOR_TOKEN_BUDGET=100000
ORCHESTRATOR_COST_LIMIT_USD=50.0

# Platform Configuration
DEBUG=false
RESULTS_DB_URL=postgresql+asyncpg://user:password@localhost/agentic_security
PAYLOADS_DIR=./payloads/
